{
  "id": "storyweald",
  "title": "Storyweald",
  "description": "Storyweald game system for Foundry VTT — data-driven ruleset profiles (Stars Without Number first). Actors and items are pushed from the Storyweald / StoryTeller world-builder through a versioned export contract.",
  "version": "0.2.0",
  "compatibility": {
    "minimum": "12",
    "verified": "14"
  },
  "authors": [
    { "name": "Steven Moore" }
  ],
  "esmodules": ["module/storyweald.mjs"],
  "styles": ["styles/storyweald.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": { "htmlFields": ["biography"] },
      "npc": { "htmlFields": ["biography"] }
    },
    "Item": {
      "gear": { "htmlFields": ["description"] },
      "ability": { "htmlFields": ["description"] }
    }
  },
  "grid": {
    "type": 1,
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "hp",
  "url": "https://github.com/Sallenmoore/storyweald-foundry",
  "manifest": "https://github.com/Sallenmoore/storyweald-foundry/releases/latest/download/system.json",
  "download": "https://github.com/Sallenmoore/storyweald-foundry/releases/latest/download/storyweald.zip",
  "license": "LICENSE",
  "readme": "README.md"
}
